# Local dev uses a SQLite file. For production (Vercel) set these to your Turso DB.
DATABASE_URL=file:local.db
# DATABASE_AUTH_TOKEN=
AUTH_SECRET=replace-with-a-long-random-string
ADMIN_PASSWORD=changeme
# Headless API keys
# API_READ_KEY=set-to-require-a-key-for-reads (leave unset for public catalog)
API_WRITE_KEY=long-random-string-required-for-writes
# API_CORS_ORIGIN=https://your-storefront.com (defaults to *)
