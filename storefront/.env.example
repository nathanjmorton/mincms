# Base URL of the MinCMS instance whose /api/products feed this storefront.
MINCMS_API_URL=https://mincms-ten.vercel.app

# Optional MinCMS write key (only needed if you push catalog changes back to MinCMS).
# MINCMS_API_KEY=

# How often (ms) to refresh the SQLite catalog cache from the API. Default 30000.
# MINCMS_REFRESH_MS=30000

# Network timeout (ms) for an API refresh before falling back to cache. Default 5000.
# MINCMS_TIMEOUT_MS=5000
